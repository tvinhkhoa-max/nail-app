    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ts-node-maintained": "^10.9.6",
    "uuid": "^13.0.0",
    "ziggy-js": "^2.6.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
