    "@tailwindcss/postcss": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ziggy-js": "^1.8.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "axios": "^1.15.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
